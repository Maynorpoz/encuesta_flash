# Ejemplo de configuración para producción
# Copiar este archivo a .env.production y actualizar con los valores reales

# Pasos para obtener las URLs:
# 1. cd aws-sam
# 2. sam deploy
# 3. Copiar ApiEndpoint y WebSocketEndpoint de los outputs

VITE_API_BASE_URL=https://YOUR_API_GATEWAY_ID.execute-api.YOUR_REGION.amazonaws.com/prod
VITE_WS_BASE_URL=wss://YOUR_WEBSOCKET_ID.execute-api.YOUR_REGION.amazonaws.com/prod
